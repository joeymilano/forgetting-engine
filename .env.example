# 智谱 GLM API Key —— 严禁提交到仓库
# 获取: https://open.bigmodel.cn/
ZHIPU_API_KEY=your_key_here

# 可选:指定模型(默认 glm-4.6,GLM Coding Plan 主力模型)
GLM_MODEL=glm-4.6

# 可选:GLM 接入端点(默认 Coding Plan OpenAI 协议端点)
# 参考: https://docs.bigmodel.cn/cn/coding-plan/quick-start
# ⚠ Coding Plan Key 与普通平台 Key 不通用,务必配套使用
GLM_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4

# 本地代理端口(需与 vite.config.ts 的 proxy target 一致)
PROXY_PORT=8787
